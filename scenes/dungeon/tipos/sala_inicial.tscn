[gd_scene format=3 uid="uid://cwaq3r7ebvr0r"]

; ============================================================
;  SALA INICIAL — Sala onde o player começa a dungeon.
;
;  Dimensões:
;    Piso  : 8 × 8 unidades
;    Paredes: 3 paredes fechadas + 1 abertura ao norte
;
;  Conectores:
;    NorthExit (0, 0, -4) → única saída, liga ao primeiro corredor
;
;  Spawn:
;    PontoSpawnJogador em (0, 1, 0) → centro da sala, acima do chão
; ============================================================

