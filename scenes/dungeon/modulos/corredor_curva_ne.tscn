[gd_scene format=4]

; TEMPLATE: Curva NE (North + East)
; Saídas: NorthExit (frente) e EastExit (direita)
; rotation_degrees.y do NorthExit = 0, do EastExit = -90 (ou 270)

[ext_resource type="Script" path="res://scenes/dungeon/sala_base.gd" id="1_base"]

[node name="CorredorCurvaNE" type="StaticBody3D"]
script = ExtResource("1_base")

[node name="Malha" type="MeshInstance3D" parent="."]

[node name="Colisao" type="CollisionShape3D" parent="."]

[node name="Saidas" type="Node3D" parent="."]

[node name="NorthExit" type="Marker3D" parent="Saidas"]
position = Vector3(0, 0, -4)
rotation_degrees = Vector3(0, 0, 0)

[node name="EastExit" type="Marker3D" parent="Saidas"]
position = Vector3(4, 0, 0)
rotation_degrees = Vector3(0, -90, 0)
